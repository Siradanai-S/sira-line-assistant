# ============================================================================
# PM LINE ASSISTANT (FREE STACK) - Environment Variables
# คัดลอกไฟล์นี้เป็น .env แล้วเติมค่าจริงให้ครบทุกบรรทัด
# ============================================================================

# ---- Server ----
PORT=3000
NODE_ENV=production
TZ=Asia/Bangkok

# ---- LINE Messaging API (ฟรี) ----
LINE_CHANNEL_ACCESS_TOKEN=your_line_long_lived_channel_access_token
LINE_CHANNEL_SECRET=your_line_channel_secret
# LINE userId ของ PM (พิมพ์ /whoami ในแชทเพื่อดู)
PM_LINE_USER_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- Supabase (ฟรี tier) ----
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ---- Google Gemini (ฟรี tier — ไม่ต้องใช้บัตรเครดิต) ----
# ขอ key ที่ https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key
# โมเดลฟรี: gemini-flash-latest (ดีฟอลต์ แนะนำ — ตามรุ่นล่าสุดเสมอ)
# หมายเหตุ: gemini-2.5-flash ถูกบล็อกสำหรับ project ใหม่แล้ว
GEMINI_MODEL=gemini-flash-latest
# ฟอร์แมตเสียงที่ LINE ส่งมา (m4a = audio/mp4) — ปกติไม่ต้องแก้
GEMINI_AUDIO_MIME=audio/mp4

# ---- Google Calendar (ฟรี — ตัวเลือกเสริม) ----
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_REDIRECT_URI=https://your-domain.com/oauth2callback
GOOGLE_REFRESH_TOKEN=your_google_refresh_token
GOOGLE_CALENDAR_ID=primary

# ---- Weather: Open-Meteo (ฟรี ไม่ต้องมี API key) ----
# ตั้งแค่พิกัด (ดีฟอลต์ = กรุงเทพฯ)
WEATHER_LAT=13.7563
WEATHER_LON=100.5018
WEATHER_CITY_NAME=กรุงเทพมหานคร

# ---- Cron ----
# โหมด Render (แนะนำ): ปิด node-cron ในแอป แล้วใช้ cron-job.org ยิงเข้า /cron/*
ENABLE_REMINDER_CRON=false
ENABLE_DAILY_REPORT_CRON=false
# secret ป้องกัน endpoint /cron/* (ตั้งเป็นสตริงสุ่มยาว ๆ) — ต้องตั้งถ้าใช้ cron-job.org
CRON_SECRET=set_a_long_random_secret_here

# โหมด Oracle/VPS (แอปไม่หลับ): จะใช้ node-cron ในแอปแทนก็ได้
# ENABLE_REMINDER_CRON=true
# ENABLE_DAILY_REPORT_CRON=true
